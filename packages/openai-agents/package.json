{
  "name": "@deny-sh/openai-agents",
  "version": "0.1.0",
  "description": "Wrap a deny.sh vault entry as an OpenAI Agents SDK tool. The credential resolves inside execute(); only a narrowed DTO reaches the model. Fail-closed leak sweep.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/index.js",
    "dist/index.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test dist-test/test/*.test.js",
    "pretest": "tsc -p tsconfig.test.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build && node ../../scripts/prepublish-verify-npm.mjs ."
  },
  "dependencies": {
    "@deny-sh/integrations-core": "^0.1.0"
  },
  "peerDependencies": {
    "@openai/agents": ">=0.1 <1"
  },
  "devDependencies": {
    "@openai/agents": "^0.11.6",
    "@types/node": "^25.6.2",
    "typescript": "^5.9.3",
    "zod": "^4.0.0"
  },
  "keywords": [
    "deny.sh",
    "openai-agents",
    "openai-agents-sdk",
    "ai-agents",
    "credential-isolation",
    "deniable",
    "vault",
    "tool-calling"
  ],
  "homepage": "https://deny.sh/integrations/openai-agents",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/deny-sh-crypto/deny-sh-integrations.git",
    "directory": "packages/openai-agents"
  },
  "license": "Apache-2.0",
  "author": "deny.sh",
  "engines": {
    "node": ">=18"
  }
}
