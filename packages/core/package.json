{
  "name": "@deny-sh/integrations-core",
  "version": "0.1.0",
  "description": "Framework-agnostic vault-entry-as-tool resolver for deny.sh. The shared security core behind every deny.sh agent-framework adapter.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/index.js",
    "dist/index.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test dist-test/test/*.test.js",
    "pretest": "tsc -p tsconfig.test.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build && node ../../scripts/prepublish-verify-npm.mjs ."
  },
  "dependencies": {
    "deny-sh": "^2.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "deny.sh",
    "ai-agents",
    "credential-isolation",
    "deniable",
    "vault",
    "tool-calling"
  ],
  "homepage": "https://deny.sh/integrations",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/deny-sh-crypto/deny-sh-integrations.git",
    "directory": "packages/core"
  },
  "license": "Apache-2.0",
  "author": "deny.sh",
  "engines": {
    "node": ">=18"
  }
}
