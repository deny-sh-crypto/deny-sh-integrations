{
  "name": "@deny-sh/vercel-ai",
  "version": "0.1.0",
  "description": "Wrap a deny.sh vault entry as a Vercel AI SDK tool. The credential resolves inside execute(); only a narrowed DTO reaches the model. Fail-closed leak sweep.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/index.js",
    "dist/index.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test dist-test/test/*.test.js",
    "pretest": "tsc -p tsconfig.test.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@deny-sh/integrations-core": "^0.1.0"
  },
  "peerDependencies": {
    "ai": ">=5 <7"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "ai": "^5.0.197",
    "typescript": "^5.9.3",
    "zod": "^3.25.76"
  },
  "keywords": [
    "deny.sh",
    "vercel-ai-sdk",
    "ai-agents",
    "credential-isolation",
    "deniable",
    "vault",
    "tool-calling"
  ],
  "homepage": "https://deny.sh/integrations/vercel-ai-sdk",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/deny-sh-crypto/deny-sh-integrations.git",
    "directory": "packages/vercel-ai"
  },
  "license": "Apache-2.0",
  "author": "deny.sh",
  "engines": {
    "node": ">=18"
  }
}
